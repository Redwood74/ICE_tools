# ============================================================
# ICEpicks – environment configuration example
# Copy to .env and fill in your values.
# NEVER commit the real .env to version control.
# ============================================================

# ----- Required -----

# Alien Registration Number (8 or 9 digits, with or without 'A-' prefix)
A_NUMBER=A-XXXXXXXXX

# Country of origin exactly as it appears in the ICE locator dropdown
# Examples: MEXICO, EL SALVADOR, GUATEMALA, HONDURAS
COUNTRY=MEXICO

# ----- Optional notification -----

# Microsoft Teams incoming webhook URL
# Leave blank to run in dry-run / console-only mode
TEAMS_WEBHOOK_URL=

# ----- Run behavior -----

# Number of fresh browser attempts per scheduled run (default: 4)
ATTEMPTS_PER_RUN=4

# Seconds to wait between attempts (default: 5.0)
ATTEMPT_DELAY_SECONDS=5.0

# Random jitter added to delay, seconds (default: 2.0)
ATTEMPT_JITTER_SECONDS=2.0

# Run browser in headless mode (default: true)
# Set to false for local debugging / visual inspection
HEADLESS=true

# ----- Paths -----

# Base directory for saved artifacts (screenshots, HTML, logs)
ARTIFACT_BASE_DIR=artifacts

# Path to the JSON state file (for deduplication)
STATE_FILE=state/findice_state.json

# ----- Logging -----

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG

# Optional log file path (leave blank to log to stderr only)
LOG_FILE=

# ----- Advanced -----

# Skip sending Teams notification (useful for testing)
DRY_RUN=false

# Browser timeouts in milliseconds
PAGE_LOAD_TIMEOUT_MS=30000
ELEMENT_TIMEOUT_MS=15000

# Enable keyring-based secret storage (requires `pip install keyring`)
FINDICE_USE_KEYRING=false
